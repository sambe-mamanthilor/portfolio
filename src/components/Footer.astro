          <li class="text-black text-sm">Production audiovisuelle</li>
        </ul>
      </div>

      {/* Social */}
      <div>
        <h4 class="font-bold mb-4">Me suivre</h4>
        <div class="flex gap-4">
          <a href="https://www.linkedin.com/in/maman-thilor-sambe-996592389/" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-primary transition-colors">
            <span class="sr-only">LinkedIn</span>
            <svg class="w-6 h-6" fill="currentColor"viewBox="0 0 24 24">
