      {/* Brand */}
      <div>
        <div class="flex items-center space-x-2 mb-6">
<div class="w-10 h-10 bg-gradient-to-br from-amber-400 to-pink-600 rounded-lg flex items-center justify-center flex-shrink-0">
          <span class="text-white font-bold text-xs">MTS</span>
        </div>          <span class="text-gray-500 text-xs">Maman Thilor SAMBE</span>
        </div>
      </div>

      {/* Quick Links */}
      <div>
        <h4 class="font-bold mb-4">Navigation</h4>
        <ul class="space-y-2">
          <li><a href="/#" class="text-black text-sm hover:text-primary transition-colors">Accueil</a></li>
          <li><a href="/#about" class="text-black text-sm hover:text-primary transition-colors">À propos</a></li>
          <li><a href="/#projects" class="text-black text-sm hover:text-primary transition-colors">Projets</a></li>
