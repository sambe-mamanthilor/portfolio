---
export interface Props {
  id: string;
  title: string;
  description: string;
  image: string;
  tags: string[];
  link?: string;
  github?: string;
  category?: string;
}

const { id, title, description, image, tags, link, github, category } = Astro.props as Props;
---

<div class="card group relative overflow-hidden h-full flex flex-col">
  {/* Image container */}
  <div class="relative h-48 sm:h-56 overflow-hidden rounded-t-lg bg-gradient-to-br from-primary/10 to-secondary/10 flex items-center justify-center">
    {image ? (
      <img 
        src={image} 
        alt={title} 
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
      />
    ) : (
      <div class="w-full h-full bg-gradient-to-br from-primary to-secondary opacity-20"></div>
    )}
    {category && (
      <div class="absolute top-3 right-3 px-3 py-1 bg-primary/90 text-white text-xs font-semibold rounded-full">
        {category}
      </div>
    )}
  </div>

  {/* Content */}
  <div class="flex-1 flex flex-col p-6">
    <h3 class="text-xl font-bold mb-2 group-hover:text-primary transition-colors">{title}</h3>
    <p class="text-gray-600 text-sm mb-4 flex-1">{description}</p>

    {/* Tags */}
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="px-3 py-1 bg-border text-primary text-xs font-medium rounded-full">
        Web
      </span>
      <span class="px-3 py-1 bg-border text-primary text-xs font-medium rounded-full">
        Design
      </span>
    </div>

    {/* Links */}
    <div class="flex gap-3">
      {link && (
        <a
          href={link}
          target="_blank"
          rel="noopener noreferrer"
          class="w-full text-center px-4 py-2 bg-gradient-to-r from-pink-500 to-purple-500 text-white rounded-lg font-medium text-sm"
        >
          Voir le projet
        </a>
      )}
    </div>
  </div>
</div>

<style>
  .card {
    @apply bg-white rounded-lg shadow-md;
  }
</style>
