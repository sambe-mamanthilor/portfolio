---
import Layout from '../layouts/Layout.astro';
import matildaImg from '../images/effet-matilda.png';
import festivalImg from '../images/festival.png';
import cuptailImg from '../images/cuptail.png';
import moiImg from '../images/moi.jpeg';     
---

<Layout title="Maman Thilor SAMBE ">
  <div class="bg-gradient-to-br from-white to-pink-500">
    {/* HERO Section */}
    <section id="hero" class="section-padding bg-gradient-to-br from-amber-300 via-pink-500 to-amber-300 relative">
      <div class="container-custom">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12 items-center">
          <div class="order-2 md:order-1">
            <div class="mb-6">
              <span class="inline-block px-4 py-2 bg-gradient-to-r from-amber-500 to-pink-500 backdrop-blur text-white font-semibold rounded-lg text-sm uppercase tracking-wide">Bienvenue</span>
            </div>
            <h1 class="text-xl sm:text-xl md:text-4xl font-bold mb-6 leading-tight text-white">
              Maman Thilor SAMBE<br class="hidden sm:block" />
            </h1>
            <p class="text-lg md:text-xl font-semibold text-white mb-8">Développement Web | Designer UX | Communication digitale| Production Audiovisuelle</p>
            <p class="text-lg text-white mb-8 leading-relaxed max-w-lg">Étudiante en <strong>BUT Métiers du Multimédia et de l'Internet (MMI)</strong> passionnée par les projets multimédias.</p>
