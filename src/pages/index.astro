            </span>
          </div>
        </div>

        {/* Soft Skills */}
        <div class="mb-16">
          <h3 class="text-2xl sm:text-xl font-bold mb-8">Soft Skills</h3>
          <div class="flex flex-wrap gap-3">
            <span class="inline-flex items-center gap-2 px-4 py-2 bg-white border-2 border-violet-300 rounded-full hover:shadow-lg transition-all hover:border-violet-500">
              <span class="font-semibold text-gray-700">Communication</span>
            </span>
            <span class="inline-flex items-center gap-2 px-4 py-2 bg-white border-2 border-violet-300 rounded-full hover:shadow-lg transition-all hover:border-violet-500">
              <img src="/images/canva.png" alt="Créativité" class="w-6 h-6" />
