                    <div class="flex justify-between items-center mb-2">
                      <span class="font-medium">Français</span>
                      <span class="text-sm text-gray-600">Niveau élevé</span>
                    </div>
                  </div>
                  <div>
                    <div class="flex justify-between items-center mb-2">
                      <span class="font-medium">Wolof</span>
                      <span class="text-sm text-gray-600">Niveau élevé</span>
                    </div>
                  </div>
                  <div>
