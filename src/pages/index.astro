              <span class="font-semibold text-gray-700">CSS3</span>
            </span>
            <span class="inline-flex items-center gap-2 px-4 py-2 bg-white border-2 border-violet-300 rounded-full hover:shadow-lg transition-all hover:border-violet-500">
              <img src="/images/javascript.png" alt="JavaScript" class="w-6 h-6" />
              <span class="font-semibold text-gray-700">JavaScript</span>
            </span>
          </div>
        </div>

        {/* Frameworks & Tools */}
        <div class="mb-16">
          <h3 class="text-xl sm:text-xl font-bold mb-8">Frameworks & Tools</h3>
