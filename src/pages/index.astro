---
import Layout from '../layouts/Layout.astro';
import matildaImg from '../images/effet-matilda.png';
import festivalImg from '../images/festival.png';
import cuptailImg from '../images/cuptail.png';
import moiImg from '../images/moi.jpeg';
import coeurImg from '../images/coeur.jpeg';
import tab1Img from '../images/tab1.jpeg';
import tab2Img from '../images/tab2.jpeg';
import plageImg from '../images/plage.jpeg';     
---

<Layout title="Maman Thilor SAMBE ">
  <div class="bg-gradient-to-br from-amber-400 to-pink-500">
    {/* HERO Section */}
    <section id="hero" class="pb-6 relative overflow-hidden bg-gradient-to-br from-amber-200 via-rose-200 to-stone-200">
      {/* Decoration */}
      <div class="absolute top-10 right-10 w-64 h-64 bg-gradient-to-br from-rose-300 to-amber-200 opacity-30 rounded-full blur-3xl organic-blob"></div>
      <div class="absolute bottom-0 left-0 w-96 h-96 bg-gradient-to-tr from-stone-300 to-rose-200 opacity-20 rounded-full blur-3xl"></div>
      
      <div class="container-custom relative z-10">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12 items-center">
          <div class="order-2 md:order-1">
            <div class="mb-6">
              <span class="inline-block px-6 py-3 bg-gradient-to-r from-rose-400 to-amber-500 text-white font-semibold rounded-full text-sm uppercase tracking-widest shadow-lg">✨ Bienvenue</span>
            </div>
            <h1 class="text-xl sm:text-4xl md:text-5xl font-bold mb-6 leading-tight text-gray-900" style="font-family: 'Playfair Display', serif;">
              Maman Thilor<br />
              <span class="bg-gradient-to-r from-rose-500 to-amber-400 bg-clip-text text-transparent">SAMBE</span>
            </h1>
            <p class="text-xl md:text-xl font-semibold text-gray-700 mb-6">Développement web • Communication digitale • Création Numérique</p>
            <p class="text-lg text-gray-600 mb-8 leading-relaxed max-w-lg">Étudiante en <strong>BUT Métiers du Multimédia et de l'Internet</strong> passionnée par des projets créatifs et innovants.</p>
            <div class="flex flex-col sm:flex-row gap-4 mb-12">
              <a href="#projects" class="btn-gradient">
                Voir mes projets
              </a>
              <a href="#contact" class="px-8 py-4 bg-white border-2 border-rose-400 text-rose-600 rounded-full font-semibold text-center hover:bg-rose-50 transition-all">
                Me contacter
              </a>
            </div>
            <div class="flex gap-6">
              <a href="https://www.linkedin.com/in/maman-thilor-sambe-996592389/" target="_blank" rel="noopener noreferrer" class="text-gray-600 hover:text-rose-500 font-semibold transition-colors text-sm uppercase tracking-wider">
                LinkedIn
              </a>
            </div>
          </div>
          <div class="order-1 md:order-2 flex justify-center">
            <div class="relative w-full max-w-md">
              <div class="absolute -inset-2 bg-gradient-to-r from-rose-500 to-amber-600 rounded-3xl blur-xl opacity-40"></div>
              <div class="relative">
                <div class="w-full aspect-square rounded-3xl bg-gradient-to-br from-white to-rose-50 border-4 border-white flex items-center justify-center overflow-hidden shadow-2xl organic-blob">
                  <img src={moiImg.src} alt="Maman SAMBE" class="w-full h-full object-cover" />
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* ABOUT Section */}
    <section id="about" class="section-padding relative bg-gradient-to-br from-amber-50 to-rose-50">
      <div class="absolute top-0 right-0 w-80 h-80 bg-rose-100 opacity-30 rounded-full blur-3xl -mr-40"></div>
      <div class="container-custom relative z-10">
        <div class="mb-12">
          <h2 class="text-3xl sm:text-6xl font-bold mb-4 text-gray-900" style="font-family: 'Playfair Display', serif;">À propos</h2>
          <div class="w-24 h-1 bg-gradient-to-r from-rose-400 to-amber-400 rounded-full mb-6"></div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-12">
          <div class="md:col-span-2">
            <div class="space-y-8">
              <div>
                <h3 class="text-xl font-bold mb-4">Qui je suis ?</h3>
                <p class="text-gray-600 text-lg leading-relaxed">
                  Je suis Maman Thilor SAMBE, une créatrice numérique passionnée par les projets multimédias ainsi qu'en communication digitale. 
                  J'aime créer des expériences utilisateur modernes, intuitives et engageantes. Mon approche combine 
                  la créativité avec la rigueur technique pour livrer des projets de haute qualité.
                </p>
              </div>
              <div>
                <h3 class="text-xl font-bold mb-4">Mon parcours</h3>
                <p class="text-gray-600 leading-relaxed mb-4">
                  Je suis actuellement en études au <strong>BUT Multimédia et Internet</strong> à l'Université Marie et Louis Pasteur/IUT Nord Franche-Comté.
                </p>
                <p class="text-gray-600 leading-relaxed">
                  Passionnée par la création numérique et le développement web, j'ai acquis des compétences
                  en développement web, communication digitale, design UX/UI & production audiovisuelle. Je suis toujours en quête
                  de nouvelles technologies et de meilleures pratiques pour créer des expériences utilisateur
                  exceptionnelles.
                </p>
              </div>
              <div>
                <h3 class="text-xl font-bold mb-4">Ce qui me motive</h3>
                <ul class="space-y-3">
                  <li class="flex items-start gap-3">
                    <span class="text-primary font-bold text-lg">→</span>
                    <span class="text-gray-600">Créer des interfaces modernes et intuitives</span>
                  </li>
                  <li class="flex items-start gap-3">
                    <span class="text-primary font-bold text-lg">→</span>
                    <span class="text-gray-600">Intervenir dans la communication digitale</span>
                  </li>
                  <li class="flex items-start gap-3">
                    <span class="text-primary font-bold text-lg">→</span>
                    <span class="text-gray-600">Travailler sur des projets multimédias variés</span>
                  </li>
                  <li class="flex items-start gap-3">
                    <span class="text-primary font-bold text-lg">→</span>
                    <span class="text-gray-600">Collaborer avec des équipes talentueuses</span>
                  </li>
                </ul>
              </div>
            </div>
          </div>
          <div>
            <div class="sticky top-24 space-y-6">
              <div class="bg-gradient-to-br from-primary/10 to-secondary/10 rounded-lg p-6 border border-border">
