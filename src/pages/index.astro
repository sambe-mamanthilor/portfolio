              <img src="/images/miro.png" alt="Miro" class="w-6 h-6" />
              <span class="font-semibold text-gray-700">Miro</span>
            </span>
            <span class="inline-flex items-center gap-2 px-4 py-2 bg-white border-2 border-violet-300 rounded-full hover:shadow-lg transition-all hover:border-violet-500">
              <img src="/images/canva.png" alt="Canva" class="w-6 h-6" />
              <span class="font-semibold text-gray-700">Canva</span>
            </span>
          </div>
        </div>

        {/* Backend & Deployment */}
        <div class="mb-16">
          <h3 class="text-2xl sm:text-xl font-bold mb-8">Backend & Deployment</h3>
          <div class="flex flex-wrap gap-3">
            <span class="inline-flex items-center gap-2 px-4 py-2 bg-white border-2 border-violet-300 rounded-full hover:shadow-lg transition-all hover:border-violet-500">
              <img src="/images/pocketbase.png" alt="PocketBase" class="w-6 h-6" />
              <span class="font-semibold text-gray-700">PocketBase</span>
            </span>
            <span class="inline-flex items-center gap-2 px-4 py-2 bg-white border-2 border-violet-300 rounded-full hover:shadow-lg transition-all hover:border-violet-500">
              <img src="/images/netlify.png" alt="Netlify" class="w-6 h-6" />
              <span class="font-semibold text-gray-700">Netlify</span>
            </span>
