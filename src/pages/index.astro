    {/* PROJECTS Section */}
    <section id="projects" class="section-padding bg-gradient-to-br from-rose-100 to-amber-100 relative overflow-hidden">
      <div class="absolute bottom-20 right-0 w-80 h-80 bg-rose-100 opacity-20 rounded-full blur-3xl"></div>
      <div class="container-custom relative z-10">
        <div class="mb-12">
          <h2 class="text-3xl sm:text-6xl font-bold mb-4 text-gray-900" style="font-family: 'Playfair Display', serif;">Projets académiques</h2>
          <div class="w-24 h-1 bg-gradient-to-r from-rose-400 to-amber-400 rounded-full mb-6"></div>
          <p class="text-xl text-gray-600 max-w-3xl">
            Voici une sélection de mes projets récents combinant développement web, UX design et créativité en mise en situation professionnelle (BUT MMI).
          </p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8 mb-16">
