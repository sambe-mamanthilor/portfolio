    {/* EDUCATION Section */}
    <section id="education" class="section-padding bg-gradient-to-br from-amber-50 via-rose-50 to-stone-100 relative overflow-hidden">
      <div class="absolute top-40 left-10 w-80 h-80 bg-rose-100 opacity-25 rounded-full blur-3xl"></div>
      <div class="container-custom relative z-10">
