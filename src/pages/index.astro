          <div class="flex flex-wrap gap-3">
            <span class="inline-flex items-center gap-2 px-4 py-2 bg-white border-2 border-violet-300 rounded-full hover:shadow-lg transition-all hover:border-violet-500">
              <img src="/images/astro.png" alt="Astro" class="w-6 h-6" />
              <span class="font-semibold text-gray-700">Astro</span>
