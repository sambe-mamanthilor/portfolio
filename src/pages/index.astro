                      <span class="font-medium">Latin</span>
                      <span class="text-sm text-gray-600">Niveau débutant</span>
                    </div>
                  </div>
                  <div>
                    <div class="flex justify-between items-center mb-2">
                      <span class="font-medium">Anglais</span>
                      <span class="text-sm text-gray-600">Niveau moyen</span>
