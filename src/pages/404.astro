---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page non trouvée - 404" description="Désolé, cette page n'existe pas">
  <div class="min-h-screen bg-gradient-to-br from-amber-50 to-amber-100 flex items-center justify-center py-12 px-4">
    <div class="max-w-md w-full text-center">
      <h1 class="text-6xl font-bold text-primary mb-4">404</h1>
      <h2 class="text-3xl font-bold mb-3">Page non trouvée</h2>
      <p class="text-gray-600 mb-8">Désolé, la page que vous cherchez n'existe pas ou a été supprimée.</p>
      <div class="flex flex-col gap-4">
        <a href="/" class="px-6 py-3 bg-gradient-to-r from-rose-400 to-amber-400 text-white rounded-lg font-semibold hover:shadow-lg transition-all">
          Retour au portfolio
        </a>
        <a href="/#contact" class="px-6 py-3 bg-white border-2 border-primary text-primary rounded-lg font-semibold hover:bg-primary hover:text-white transition-all">
          Me contacter
        </a>
      </div>
    </div>
  </div>
</Layout>
